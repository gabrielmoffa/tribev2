# Hugging Face credentials and target repos.
# Copy this file to `.env` and fill in your values, or export these variables in your shell.

# Required for HF Jobs / model downloads / dataset uploads.
HF_TOKEN=

# Your Hugging Face username (used as the namespace where HF Jobs run).
HF_NAMESPACE=

# Private dataset repo where job inputs and prediction artifacts are uploaded.
# Format: <namespace>/<repo-name>, e.g. yourname/tribe-job-artifacts
HF_DATASET_REPO=

# Optional: Space repo for `scripts/deploy_hf_space.py`.
# Format: <namespace>/<repo-name>, e.g. yourname/tribe-video-brain-review
HF_SPACE_REPO=

# Optional: enable running TRIBE inference on this machine instead of HF Jobs.
# Only useful if you have a CUDA GPU or a powerful Apple Silicon Mac.
TRIBE_ALLOW_LOCAL=
